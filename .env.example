# OpenAlex API
OPENALEX_EMAIL=tu_email@ejemplo.com

# Rutas de datos
DATA_DIR=data
RAW_DIR=data/raw
OCR_DIR=data/ocr
GROUND_TRUTH_DIR=data/ground_truth
PAIRS_DIR=data/pairs

# Modelo
MODEL_NAME=google/flan-t5-base
MODEL_PATH=models/ocr-corrector
MAX_INPUT_LENGTH=512
MAX_OUTPUT_LENGTH=512

# Entrenamiento
BATCH_SIZE=8
LEARNING_RATE=5e-5
NUM_EPOCHS=3
SEED=42

# API (opcional)
API_HOST=0.0.0.0
API_PORT=8000
